# mod-chat BFF + web (E-18)

BFF_PORT=4000
WEB_ORIGIN=http://localhost:5173
QUERY_BASE_URL=http://localhost:8010

# Dev: skip Keycloak and use stub session
AUTH_STUB=true
DEFAULT_TENANT_ID=dev
DEFAULT_COLLECTIONS=docs,payments-api

# Forward to query (dev MCP token or user JWT when AUTH_STUB=false)
QUERY_ACCESS_TOKEN=
MCP_ACCESS_TOKEN=

# Keycloak OIDC (production)
OIDC_ISSUER=http://localhost:8081/realms/hybrid-rag
OIDC_CLIENT_ID=mod-chat
SESSION_SECRET=generate-with-openssl-rand-hex-32
