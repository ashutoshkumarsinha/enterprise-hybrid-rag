# hybrid-rag-inference — copy to inference.toml

[project]
name = "hybrid-rag-inference"
version = "1.0.0"
profile = "gpu_24gb"   # dev | gpu_24gb | a100_80gb

[models]
chat_llm = "meta-llama/Llama-3.2-3B-Instruct"
embed = "intfloat/e5-base-v2"
vision = "Qwen/Qwen2-VL-7B-Instruct"
reranker = "BAAI/bge-reranker-large"
reranker_fast = "cross-encoder/ms-marco-MiniLM-L-6-v2"
smoke_llm = "meta-llama/Llama-3.2-1B-Instruct"
embed_dimension = 768

[chat_llm]
port = 8000
max_model_len = 16384
gpu_memory_utilization = 0.90
max_num_seqs = 16

[embedding]
port = 8001

[vision_llm]
port = 8002
max_model_len = 8192
enabled = true   # false for PROFILE=dev

[reranker]
port = 8091

[reranker_fast]
port = 8092

[smoke_llm]
port = 8011
max_model_len = 4096
enabled = false  # true for PROFILE=dev
