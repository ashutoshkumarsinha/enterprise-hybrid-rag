{
  "realm": "hybrid-rag",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "viewer",
        "description": "Read-only catalog and graph — no research"
      },
      {
        "name": "user",
        "description": "Standard RAG researcher — research + sessions"
      },
      {
        "name": "collection-admin",
        "description": "Collection team lead — admin diagnostics + research"
      },
      {
        "name": "admin",
        "description": "Platform administrator — all MCP permissions"
      }
    ]
  },
  "clients": [
    {
      "clientId": "mod-chat",
      "name": "mod-chat BFF",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:4000/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:4000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "hybrid-rag-query",
      "name": "MCP / query bearer validation",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    }
  ]
}
