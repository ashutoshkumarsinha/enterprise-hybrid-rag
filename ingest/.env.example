# hybrid-rag-ingest secrets
PROFILE=default

ORCHESTRATOR_PORT=8020
CELERY_CONCURRENCY=4

# infra (hybrid-rag-net hostnames)
QDRANT_URL=http://qdrant:6333
QDRANT_GRPC_PORT=6334
PREFER_QDRANT_GRPC=false
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-in-production
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
JOB_POLL_CELERY=true
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=hybrid-rag-ingest
MINIO_SECRET_KEY=change-me-ingest-minio
MINIO_BUCKET=hybrid-rag
MINIO_BUCKET_STAGING=hybrid-rag-staging
MINIO_REGION=us-east-1
CATALOG_DSN=postgresql://ingest_rw:change-me-ingest@postgres:5432/catalog

# inference
VLLM_EMBED_URL=http://embedding:8001/v1
VLLM_VISION_URL=http://vision-llm:8002/v1
EMBED_MODEL=intfloat/e5-base-v2

# observability (OTLP → collector → Jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_NAME=hybrid-rag-ingest
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
DEPLOY_ENV=dev

# Optional LangSmith (ingest task traces — off by default)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=hybrid-rag-ingest

# paths
DOCUMENTS_SOURCE_DIR=/data/sources

# parsers (dev: stub PDF/DOCX/docling when optional deps missing)
PARSER_STUB=true
PARSER_PROFILE=fast

# store writes (dev: skip actual Qdrant/Neo4j/embed calls)
INGEST_WRITE_STUB=true
EMBED_STUB=true
QDRANT_STUB=true
NEO4J_STUB=true
EMBED_DIMENSION=768
QDRANT_COLLECTION=enterprise_hybrid_rag
INGEST_BATCH_SIZE=32
QDRANT_UPSERT_BATCH=100
NEO4J_UNWIND_BATCH=50

# ACL events (query cache invalidation)
REDIS_EVENTS_STREAM=rag:events
REDIS_DEDUP_URL=redis://redis:6379/0
DEDUP_ENABLED=true
DEDUP_MGET_BATCH=100

# connectors (dev: stub S3 list/fetch without MinIO)
CONNECTOR_STUB=true
S3_ENABLED=false
FILESYSTEM_CONNECTOR_ENABLED=true

# Celery beat (PROFILE=beat)
CONNECTOR_BEAT_ENABLED=false
CONNECTOR_SYNC_INTERVAL_MINUTES=60
# JSON array of {tenant_id, collection_id, connector, mode, prefix}
CONNECTOR_BEAT_TARGETS=[]

# Backpressure (FR-29)
INGEST_BACKPRESSURE_ENABLED=true
INGEST_BACKPRESSURE_WARN_DEPTH=100
INGEST_BACKPRESSURE_PAUSE_DEPTH=1000

# Quota enforcement (FR-30)
QUOTA_ENFORCEMENT_ENABLED=true
