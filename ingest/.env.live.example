# Live-stack integration profile — copy to .env and merge with compose URLs.
# Run: LIVE_STACK=1 LIVE_STACK_STRICT=1 pytest tests/integration -q

ORCHESTRATOR_PORT=8020

# Disable stubs for live ingest write tests
INGEST_WRITE_STUB=false
EMBED_STUB=false
QDRANT_STUB=false
NEO4J_STUB=false
DEDUP_ENABLED=false
CONNECTOR_STUB=true

QDRANT_URL=http://127.0.0.1:6333
QDRANT_GRPC_PORT=6334
PREFER_QDRANT_GRPC=true
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-in-production
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=hybrid-rag-ingest
MINIO_SECRET_KEY=change-me-ingest-minio
MINIO_BUCKET=hybrid-rag
VLLM_EMBED_URL=http://127.0.0.1:8001/v1
EMBED_DIMENSION=768
QDRANT_COLLECTION=enterprise_hybrid_rag

PARSER_STUB=true
PARSER_PROFILE=fast
