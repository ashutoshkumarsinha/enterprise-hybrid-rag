{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybrid-rag.local/schemas/chunk_payload.v1.json",
  "title": "QdrantChunkPayload",
  "description": "Normative chunk payload for index_schema_version=1. Spec §4.2.",
  "type": "object",
  "required": [
    "uuid",
    "tenant_id",
    "collection_id",
    "document_id",
    "version_id",
    "title",
    "text",
    "type",
    "ingested_at"
  ],
  "additionalProperties": true,
  "properties": {
    "uuid": { "type": "string", "format": "uuid" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "collection_id": { "type": "string", "minLength": 1 },
    "document_id": { "type": "string", "minLength": 1 },
    "version_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "text": { "type": "string" },
    "section_id": { "type": "string" },
    "section_title": { "type": "string" },
    "parent_section_id": { "type": "string" },
    "page_number": { "type": "integer", "minimum": 0 },
    "chunk_index": { "type": "integer", "minimum": 0 },
    "type": {
      "type": "string",
      "enum": ["text", "table", "code", "visual", "faq"]
    },
    "language": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "source_uri": { "type": "string" },
    "source_system": { "type": "string" },
    "acl_principal": { "type": "array", "items": { "type": "string" } },
    "references": { "type": "array", "items": { "type": "string" } },
    "image_url": { "type": "string", "format": "uri" },
    "ingested_at": { "type": "string", "format": "date-time" },
    "content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
