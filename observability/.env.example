# hybrid-rag-observability — copy to .env

# Langfuse (self-hosted in this stack — observability/compose)
LANGFUSE_POSTGRES_PASSWORD=langfuse
LANGFUSE_NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
LANGFUSE_SALT=generate-with-openssl-rand-hex-32
LANGFUSE_PUBLIC_URL=http://localhost:3000
LANGFUSE_PORT=3000
LANGFUSE_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Headless init — Langfuse creates org/project/API keys on startup (no UI step).
# Run: ./scripts/ensure_langfuse_init.sh  then  ../scripts/bootstrap_langfuse_keys.sh
LANGFUSE_INIT_ORG_ID=hybrid-rag
LANGFUSE_INIT_ORG_NAME=Enterprise-Hybrid-RAG
LANGFUSE_INIT_PROJECT_ID=hybrid-rag-query
LANGFUSE_INIT_PROJECT_NAME=hybrid-rag-query
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=admin@hybrid-rag.local
LANGFUSE_INIT_USER_NAME=Hybrid RAG Admin
LANGFUSE_INIT_USER_PASSWORD=

# Consumer apps (auto-synced to query/.env by bootstrap_langfuse_keys.sh):
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://langfuse:3000

# OpenTelemetry Collector
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
DEPLOY_ENV=dev
JAEGER_OTLP_ENDPOINT=jaeger:4317

# Production collector profile (make up PROFILE=prod) — OBS-P1
TRACE_SAMPLING_PERCENTAGE=25
# COLLECTOR_CONFIG=../collector/otel-collector-config.prod.yaml  # set by Makefile PROFILE=prod

# SigNoz API import (E-23) — make import-signoz or python scripts/import_signoz.py --apply
# SIGNOZ_API_URL=http://localhost:8080
# SIGNOZ_API_KEY=

# Jaeger UI (trace visualization)
JAEGER_UI_PORT=16686
# Dev: in-memory traces (default). Prod/staging: make up PROFILE=jaeger-persist (OBS-P4)
# JAEGER_STORAGE_TYPE=memory
# JAEGER_BADGER_EPHEMERAL=true
JAEGER_TRACE_RETENTION=168h

# SigNoz (optional — make up PROFILE=signoz)
# Uses collector/otel-collector-config.signoz.yaml fan-out to signoz-otel-collector
SIGNOZ_OTLP_ENDPOINT=signoz-otel-collector:4317
# COLLECTOR_CONFIG=../collector/otel-collector-config.signoz.yaml  # set by Makefile PROFILE=signoz

# Prometheus scrape target for collector metrics (:8889/metrics)
PROMETHEUS_PORT=9090

# Copy to query/ingest .env — automated via: make bootstrap-langfuse-keys
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
