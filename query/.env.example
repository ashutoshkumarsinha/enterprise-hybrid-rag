# hybrid-rag-query secrets
QUERY_PORT=8010

# infra (hybrid-rag-net)
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=enterprise_hybrid_rag
QDRANT_STUB=true
EMBED_STUB=true
CHAT_STUB=true
RERANKER_STUB=true
REDIS_STUB=true
QUERY_CACHE_ENABLED=false
QUERY_EVENTS_ENABLED=true
REDIS_EVENTS_STREAM=rag:events
EMBED_DIMENSION=768
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-in-production
NEO4J_STUB=true
REDIS_URL=redis://redis:6379/0
CATALOG_DSN_RO=postgresql://query_ro:change-me-query@postgres:5432/catalog
CATALOG_DSN_SESSION=postgresql://query_session_rw:change-me-query-session@postgres:5432/catalog
CATALOG_DSN_TOKEN=postgresql://query_token_rw:change-me-query-token@postgres:5432/catalog

# Auth / RBAC (dev defaults — set AUTH_REQUIRED=true in production)
AUTH_REQUIRED=false
RBAC_ENABLED=true
JWT_BRIDGE=true
JWT_STUB=false
OIDC_ISSUER=http://keycloak:8080/realms/hybrid-rag
JWKS_URI=http://keycloak:8080/realms/hybrid-rag/protocol/openid-connect/certs
JWT_AUDIENCE=
MCP_ACCESS_TOKEN=
ALLOW_TOKEN_BOOTSTRAP=true
SESSIONS_ENABLED=true
DEFAULT_TENANT_ID=dev
DEFAULT_PRINCIPAL=user:dev
STUB_HEALTH=true
CIRCUIT_BREAKERS_ENABLED=true
SUPERVISOR_ENABLED=true
# Live integration profile: copy query/.env.live.example when running make integration
HISTORY_AWARE_SUPERVISOR=false
SKIP_SUPERVISOR_WHEN_EXPLICIT=true
SCOPE_INFERENCE_THRESHOLD=0.7

# infra object store (presigned image URLs in answers)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=hybrid-rag-query
MINIO_SECRET_KEY=change-me-query-minio
MINIO_BUCKET=hybrid-rag
MINIO_PRESIGN_TTL_SECONDS=3600

# inference
VLLM_URL=http://chat-llm:8000/v1
VLLM_EMBED_URL=http://embedding:8001/v1
RERANKER_URL=http://reranker:8091
RERANKER_FAST_URL=http://reranker-fast:8092
CHAT_LLM_MODEL=meta-llama/Llama-3.2-3B-Instruct
EMBED_MODEL=intfloat/e5-base-v2

# LangSmith (optional — LangGraph trace export from query/ingest)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=hybrid-rag-query
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# observability (Langfuse server in observability/ — SDK keys from Langfuse UI)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
# OpenTelemetry (export to hybrid-rag-observability collector)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_NAME=hybrid-rag-query
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
DEPLOY_ENV=dev

MCP_BEARER_TOKEN=
