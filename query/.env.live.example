# Live-stack integration profile — copy to .env and merge with compose URLs.
# Run: LIVE_STACK=1 LIVE_STACK_STRICT=1 pytest tests/integration -q

QUERY_PORT=8010

# Disable all stubs (required for LIVE_STACK=1)
QDRANT_STUB=false
EMBED_STUB=false
CHAT_STUB=false
RERANKER_STUB=false
REDIS_STUB=false
NEO4J_STUB=false
STUB_HEALTH=false
QUERY_CACHE_ENABLED=true
CIRCUIT_BREAKERS_ENABLED=true

# infra (hybrid-rag-net — start infra + inference before query)
QDRANT_URL=http://127.0.0.1:6333
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-in-production
REDIS_URL=redis://127.0.0.1:6379/0
CATALOG_DSN_RO=postgresql://query_ro:change-me-query@127.0.0.1:5432/catalog
CATALOG_DSN_SESSION=postgresql://query_session_rw:change-me-query-session@127.0.0.1:5432/catalog
CATALOG_DSN_TOKEN=postgresql://query_token_rw:change-me-query-token@127.0.0.1:5432/catalog

# inference (vLLM + reranker sidecars)
VLLM_URL=http://127.0.0.1:8000/v1
VLLM_EMBED_URL=http://127.0.0.1:8001/v1
RERANKER_URL=http://127.0.0.1:8091
EMBED_DIMENSION=768

# Optional: hit a running query container instead of in-process TestClient only
# QUERY_BASE_URL=http://127.0.0.1:8010

# Integration test scope
DEFAULT_TENANT_ID=dev
LIVE_TEST_COLLECTION_ID=payments-api

AUTH_REQUIRED=false
ALLOW_TOKEN_BOOTSTRAP=true
SUPERVISOR_ENABLED=true
